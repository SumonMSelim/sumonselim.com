---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import MatrixRain from "@/components/MatrixRain";
import ScanlineOverlay from "@/components/ScanlineOverlay";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import ScrollToTop from "@/components/ScrollToTop";
import ShareButtons from "@/components/ShareButtons";
import ImageLightbox from "@/components/ImageLightbox";
import CodeEnhancer from "@/components/CodeEnhancer";
import Embed from "@/components/mdx/Embed.astro";
import Gallery from "@/components/mdx/Gallery.astro";
import Image from "@/components/mdx/Image.astro";
import { formatDate } from "@/lib/types";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  articles.sort((a, b) => b.data.date.localeCompare(a.data.date));

  const articlePaths = articles.map((entry, i) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      collection: "articles" as const,
      prevPost: i < articles.length - 1
        ? { slug: articles[i + 1].slug, title: articles[i + 1].data.title }
        : null,
      nextPost: i > 0
        ? { slug: articles[i - 1].slug, title: articles[i - 1].data.title }
        : null,
    },
  }));

  const pages = await getCollection("pages");
  const pagePaths = pages.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, collection: "pages" as const, prevPost: null, nextPost: null },
  }));

  return [...articlePaths, ...pagePaths];
}

const { entry, collection, prevPost, nextPost } = Astro.props;
const { Content } = await entry.render();

const siteURL = "https://www.sumonselim.com";
const isArticle = collection === "articles";

const title = entry.data.title;
const canonicalURL = `${siteURL}/${entry.slug}`;

// Article-only fields
const date = isArticle ? (entry.data as any).date : null;
const tag = isArticle ? (entry.data as any).tag : null;
const excerpt = isArticle ? (entry.data as any).excerpt : null;

const wordCount = entry.body.split(/\s+/).length;
const readingMins = Math.max(1, Math.ceil(wordCount / 200));

const breadcrumbJsonLd = isArticle ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteURL },
    { "@type": "ListItem", "position": 2, "name": "Articles", "item": `${siteURL}/articles` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL },
  ],
}) : null;

const articleJsonLd = isArticle ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": excerpt ?? title,
  "datePublished": date,
  "dateModified": date,
  "inLanguage": "en-US",
  "wordCount": wordCount,
  "timeRequired": `PT${readingMins}M`,
  "author": {
    "@type": "Person",
    "name": "Muhammad Sumon Molla Selim",
    "url": `${siteURL}/about`,
    "sameAs": [
      "https://github.com/SumonMSelim",
      "https://linkedin.com/in/sumonmselim",
      "https://twitter.com/SumonMSelim",
    ],
  },
  "publisher": {
    "@type": "Person",
    "name": "Muhammad Sumon Molla Selim",
    "url": siteURL,
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL },
  "url": canonicalURL,
  "keywords": tag,
}) : null;
---

<Layout
  title={`${title} — Muhammad Sumon Molla Selim | Senior Software Engineer`}
  description={excerpt ?? title}
  ogImage={isArticle ? `/og/${entry.slug}.png` : undefined}
  ogImageAlt={title}
  ogType={isArticle ? "article" : "website"}
  publishedTime={date ?? undefined}
  keywords={tag ?? undefined}
  canonicalURL={canonicalURL}
>
  {breadcrumbJsonLd && <script type="application/ld+json" slot="head" set:html={breadcrumbJsonLd} />}
  {articleJsonLd && <script type="application/ld+json" slot="head" set:html={articleJsonLd} />}

  <MatrixRain client:idle />
  <ScanlineOverlay client:idle />
  <Navbar currentPath={Astro.url.pathname} client:load />

  <main class="relative z-10 pt-20 pb-10">
    <div class="container mx-auto px-4 max-w-4xl">

      <div class="mb-8 flex gap-3">
        <a href="/" class="cli-command text-xs">&gt;<span class="cursor-blink">_</span> cd ~</a>
        {isArticle && (
          <a href="/articles" class="cli-command text-xs">&gt;<span class="cursor-blink">_</span> articles</a>
        )}
      </div>

      <article itemscope itemtype={isArticle ? "https://schema.org/Article" : undefined}>
        <header class="mb-10">
          {isArticle && (
            <div class="flex flex-wrap items-center gap-3 mb-4">
              <a
                href={`/articles?tag=${encodeURIComponent(tag)}`}
                class="font-mono text-xs px-2 py-0.5 rounded-full border border-primary/30 bg-primary/10 text-primary hover:bg-primary/20 transition-colors"
              >
                {tag}
              </a>
              <span class="font-mono text-xs text-muted-foreground">{formatDate(date)}</span>
              <span class="font-mono text-xs text-muted-foreground ml-auto">~{readingMins} min read</span>
            </div>
          )}
          <h1 itemprop={isArticle ? "headline" : undefined} class="font-display text-2xl sm:text-3xl lg:text-4xl text-foreground leading-tight">
            {title}
          </h1>
        </header>

        <div itemprop={isArticle ? "articleBody" : undefined} class="rich-content space-y-6 text-foreground/90 leading-[1.8] text-base sm:text-lg">
          <Content components={{ Embed, Gallery, img: Image }} />
        </div>

        {isArticle ? (
          <>
            <div class="mt-12 mb-6 border-t border-border pt-6">
              <ShareButtons title={title} url={canonicalURL} client:load />
            </div>
            <div class="mb-2">
              <p class="font-mono text-xs text-muted-foreground">
                // end of article — <span class="text-primary">process exited with code 0</span>
              </p>
            </div>
          </>
        ) : (
          <div class="mt-12 border-t border-border pt-4">
            <p class="font-mono text-xs text-muted-foreground">
              // end of page — <span class="text-primary">process exited with code 0</span>
            </p>
          </div>
        )}
      </article>

      {isArticle && (prevPost || nextPost) && (
        <nav
          class="mt-10 pt-6 border-t border-border grid grid-cols-2 gap-4"
          aria-label="Article navigation"
        >
          <div>
            {prevPost && (
              <a
                href={`/${prevPost.slug}`}
                class="group flex flex-col gap-1 p-4 rounded-lg border border-border bg-card hover:border-primary transition-colors"
              >
                <span class="font-mono text-xs text-muted-foreground">← older</span>
                <span class="text-sm text-foreground group-hover:text-primary transition-colors line-clamp-2">
                  {prevPost.title}
                </span>
              </a>
            )}
          </div>
          <div>
            {nextPost && (
              <a
                href={`/${nextPost.slug}`}
                class="group flex flex-col gap-1 p-4 rounded-lg border border-border bg-card hover:border-primary transition-colors text-right"
              >
                <span class="font-mono text-xs text-muted-foreground">newer →</span>
                <span class="text-sm text-foreground group-hover:text-primary transition-colors line-clamp-2">
                  {nextPost.title}
                </span>
              </a>
            )}
          </div>
        </nav>
      )}

    </div>
  </main>

  <ImageLightbox client:idle />
  {isArticle && <CodeEnhancer client:idle />}
  <Footer />
  <ScrollToTop client:idle />
</Layout>

<style is:global>
  /* Rich HTML content (MDX-rendered article/page body) */
  .rich-content h1 { @apply font-display text-2xl sm:text-3xl text-foreground mt-8 mb-4 leading-tight; }
  .rich-content h2 { @apply font-display text-xl sm:text-2xl text-foreground mt-8 mb-3 leading-tight; }
  .rich-content h3 { @apply font-display text-lg sm:text-xl text-foreground mt-6 mb-2 leading-tight; }
  .rich-content h4 { @apply font-mono text-base text-primary mt-5 mb-2 font-semibold; }
  .rich-content h5, .rich-content h6 { @apply font-mono text-sm text-primary mt-4 mb-1 font-semibold; }
  .rich-content p { @apply mb-0 leading-[1.8] text-foreground/90; }
  .rich-content ul { @apply list-disc pl-6 space-y-1 my-4; }
  .rich-content ol { @apply list-decimal pl-6 space-y-1 my-4; }
  .rich-content li { @apply text-foreground/90 leading-[1.8]; }
  .rich-content a { @apply text-primary relative transition-colors duration-300; text-decoration: none; }
  .rich-content a::after { content: ''; @apply absolute bottom-0 left-0 w-0 h-[1px] bg-primary transition-all duration-300 ease-out; }
  .rich-content a:hover::after { @apply w-full; }
  .rich-content a:hover { @apply text-primary; text-shadow: 0 0 8px hsl(var(--glow) / 0.3); }
  .rich-content strong, .rich-content b { @apply font-semibold text-foreground; }
  .rich-content em, .rich-content i { @apply italic; }
  .rich-content :not(pre) > code { @apply font-mono text-sm bg-card px-1.5 py-0.5 rounded border border-border text-primary; }
  .rich-content blockquote { @apply border-l-2 border-primary pl-4 my-4 italic text-muted-foreground; }
  .rich-content hr { @apply border-border my-6; }
  .rich-content table { @apply w-full border-collapse my-6 text-left text-sm; }
  .rich-content thead { @apply border-b-2 border-border; }
  .rich-content th { @apply font-semibold text-foreground py-3 px-4 bg-card/50; }
  .rich-content td { @apply py-3 px-4 border-b border-border text-foreground/90 align-top; }
  .rich-content tbody tr:hover { @apply bg-card/30; }
  .rich-content figcaption { display: none; }
  .rich-content img + em { display: none; }

  /* Code block wrapper (CodeEnhancer.tsx) */
  .code-block-wrapper {
    @apply my-6 rounded-lg border border-border overflow-hidden;
    box-shadow: 0 0 16px hsl(var(--glow) / 0.08);
  }
  .code-block-header {
    @apply flex items-center justify-between px-4 py-2 border-b border-border bg-card font-mono;
  }
  .code-block-lang { @apply text-xs text-primary font-semibold tracking-wide uppercase; }
  .code-block-copy {
    @apply flex items-center gap-1.5 text-xs text-muted-foreground hover:text-primary transition-colors px-2 py-1 rounded border border-border hover:border-primary/60 bg-transparent;
  }
  .code-block-wrapper pre.astro-code { @apply my-0 rounded-none border-0; }

  /* Shiki code blocks */
  .rich-content pre,
  pre.astro-code {
    @apply rounded-lg border border-border overflow-x-auto my-6 text-sm;
    padding: 1rem 1.25rem;
    line-height: 1.6;
  }
  pre.astro-code code {
    counter-reset: line;
    display: block;
    white-space: normal;
  }
  pre.astro-code .line {
    display: block;
    counter-increment: line;
    padding-left: 3.5rem;
    position: relative;
    line-height: 1.6;
    white-space: pre;
  }
  pre.astro-code .line:empty { min-height: 1.6em; }
  pre.astro-code .line::before {
    content: counter(line);
    position: absolute;
    left: 0;
    width: 2.5rem;
    text-align: right;
    padding-right: 0.75rem;
    @apply border-r border-border text-muted-foreground/40;
    font-size: 0.75em;
    line-height: inherit;
    user-select: none;
  }
  pre.astro-code .line:empty::before { content: counter(line); }
  pre.astro-code .line:empty:last-child { display: none; }

  /* Shiki dual-theme */
  .astro-code, .astro-code span {
    color: var(--shiki-light) !important;
    background-color: var(--shiki-light-bg) !important;
    font-style: var(--shiki-light-font-style) !important;
    font-weight: var(--shiki-light-font-weight) !important;
    text-decoration: var(--shiki-light-text-decoration) !important;
  }
  .dark .astro-code, .dark .astro-code span {
    color: var(--shiki-dark) !important;
    background-color: var(--shiki-dark-bg) !important;
    font-style: var(--shiki-dark-font-style) !important;
    font-weight: var(--shiki-dark-font-weight) !important;
    text-decoration: var(--shiki-dark-text-decoration) !important;
  }
</style>
