---
/**
 * Embed component for MDX files.
 * Detects YouTube/Vimeo and uses 16:9 aspect ratio; everything else uses fixed height.
 */
interface Props {
  url: string;
  title?: string;
  height?: number;
}

const { url, title = "Embedded content", height = 400 } = Astro.props;
const isVideo = /youtube|youtu\.be|vimeo/i.test(url);
---

<div class="rounded-lg overflow-hidden border border-border my-6">
  {isVideo ? (
    <div class="relative w-full" style="padding-bottom: 56.25%">
      <iframe
        src={url}
        title={title}
        class="absolute inset-0 w-full h-full"
        allowfullscreen
        loading="lazy"
      />
    </div>
  ) : (
    <iframe
      src={url}
      title={title}
      width="100%"
      height={height}
      loading="lazy"
      class="border-0 block"
      allow="encrypted-media"
    />
  )}
</div>
